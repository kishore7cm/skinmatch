# Copy to .env and fill in your Supabase project's values.
# The Anthropic key itself is NOT here — it lives server-side as a Supabase
# Edge Function secret (see supabase/functions/extract-ingredients/index.ts).
EXPO_PUBLIC_SUPABASE_FUNCTION_URL=https://<project-ref>.supabase.co/functions/v1/extract-ingredients
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
