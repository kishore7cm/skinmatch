# Copy to .env and fill in your Firebase project's function URLs.
# The Anthropic key itself is NOT here — it lives server-side as a Firebase
# Functions secret (see functions/src/index.ts).
EXPO_PUBLIC_FIREBASE_FUNCTION_URL=https://<region>-<project-id>.cloudfunctions.net/extractIngredients

# Product submission flow (see functions/src/index.ts)
EXPO_PUBLIC_SUBMIT_PRODUCT_URL=https://<region>-<project-id>.cloudfunctions.net/submitProduct
EXPO_PUBLIC_GET_MY_SUBMISSIONS_URL=https://<region>-<project-id>.cloudfunctions.net/getMySubmissions
EXPO_PUBLIC_GET_APPROVED_SUBMISSIONS_URL=https://<region>-<project-id>.cloudfunctions.net/getApprovedSubmissions
EXPO_PUBLIC_EXTRACT_PRODUCT_INFO_URL=https://<region>-<project-id>.cloudfunctions.net/extractProductInfo
