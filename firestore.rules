rules_version = '2';

// No client ever talks to Firestore directly in this app — every read/write
// goes through a Cloud Function using the Admin SDK, which bypasses these
// rules entirely. This is a defensive deny-all, not the real access control.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
